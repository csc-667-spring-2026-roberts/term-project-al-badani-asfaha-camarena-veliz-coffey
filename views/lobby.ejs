<%- include('partials/header', { title: 'Lobby' }) %>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof title !=="undefined" ? title : "Exploding Kittens" %>
  </title>
  <link rel="stylesheet" href="/css/styles.css">
  <script src="/js/lobby.js" defer></script>
</head>

<main>
  <div class="center-wrapper center-elements">
    <h1>Account Info</h1>
    <div>
      <img src="<%= avatar %>" alt="Avatar" class="avatar">
    </div>
    <div>
      <p>Email: <%= email %></p>
    </div>
    <div>
      <a href="/logout" class="btn-style">Logout</a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
