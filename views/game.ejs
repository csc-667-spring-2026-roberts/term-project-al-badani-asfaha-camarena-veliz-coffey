<%- include('partials/header', { title: 'Game' }) %>

<header class="site-header">
  <a href="/lobby" class="logo">💣 Exploding Kittens</a>
  <a href="/lobby" class="btn btn-secondary" style="font-size:.875rem; padding:.45rem 1rem;">← Back to Lobby</a>
</header>

<main>
  <div class="game-room">
    <span class="bomb-icon">💣</span>
    <h1>Game #<%= gameId %></h1>
    <p style="color:var(--text-muted);">Waiting for players to join…</p>
  </div>
  <%- include('partials/thread', { gameId: gameId, user: user }) %>
</main>

<%- include('partials/footer') %>